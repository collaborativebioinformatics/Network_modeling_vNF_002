/*
================================================================================
  nextflow.config — Synthetic Node Expansion Pipeline
================================================================================
*/

// ---------------------------------------------------------------------------
// Default parameters (overridden by CLI or profile)
// ---------------------------------------------------------------------------
params {
    nodes              = null
    edges              = null
    similarity         = 0.8
    entropy_threshold  = 0.95
    low_dim            = 8
    max_rounds         = 50
    outdir             = "results"
    help               = false
}

// ---------------------------------------------------------------------------
// Process resource labels
// ---------------------------------------------------------------------------
process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
        time   = '1 h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '32 GB'
        time   = '4 h'
    }
    withLabel: 'process_high' {
        cpus   = 16
        memory = '64 GB'
        time   = '12 h'
    }
}

// ---------------------------------------------------------------------------
// Docker (default container — used across all profiles)
// ---------------------------------------------------------------------------
docker {
    enabled    = true
    runOptions = '--gpus all'       // ignored gracefully on non-GPU hosts
}

process.container = 'nvcr.io/nvidia/rapidsai/base:24.10-cuda12.5-py3.12'

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------
profiles {

    // -------------------------------------------------------------------------
    // Local — CPU or single GPU workstation
    // -------------------------------------------------------------------------
    local {
        docker.enabled  = true
        process {
            withLabel: 'process_high' {
                cpus   = 8
                memory = '32 GB'
            }
        }
        executor {
            name     = 'local'
            cpus     = 16
            memory   = '64 GB'
        }
    }

    // -------------------------------------------------------------------------
    // SLURM — HPC cluster with optional GPU partition
    // -------------------------------------------------------------------------
    slurm {
        docker.enabled    = false
        singularity {
            enabled        = true
            autoMounts     = true
            // Convert Docker image to Singularity automatically
            // or supply a pre-built .sif file path here
        }

        process {
            executor       = 'slurm'
            queue          = 'gpu'
            clusterOptions = '--gres=gpu:1'

            withLabel: 'process_low' {
                queue          = 'cpu'
                clusterOptions = ''
                cpus           = 2
                memory         = '8 GB'
                time           = '1 h'
            }
            withLabel: 'process_medium' {
                cpus           = 8
                memory         = '64 GB'
                time           = '4 h'
            }
            withLabel: 'process_high' {
                cpus           = 16
                memory         = '128 GB'
                time           = '24 h'
                clusterOptions = '--gres=gpu:a100:1'
            }
        }
    }

    // -------------------------------------------------------------------------
    // AWS Batch
    // -------------------------------------------------------------------------
    aws {
        docker.enabled = true

        process {
            executor       = 'awsbatch'
            queue          = 'synthetic-node-expansion-queue'   // your Batch queue

            withLabel: 'process_low' {
                cpus   = 2
                memory = '8 GB'
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = '32 GB'
            }
            withLabel: 'process_high' {
                cpus          = 16
                memory        = '64 GB'
                // GPU-enabled instance — requires GPU Batch compute env
                containerOptions = '--runtime=nvidia'
            }
        }

        aws {
            region         = 'us-east-1'         // update to your region
            batch {
                cliPath    = '/usr/local/bin/aws'
            }
        }

        workDir = 's3://your-bucket/nextflow-work'   // update to your S3 bucket
    }

    // -------------------------------------------------------------------------
    // Google Cloud Life Sciences / Cloud Batch
    // -------------------------------------------------------------------------
    gcp {
        docker.enabled = true

        process {
            executor = 'google-lifesciences'

            withLabel: 'process_low' {
                cpus   = 2
                memory = '8 GB'
                time   = '1 h'
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = '32 GB'
                time   = '4 h'
            }
            withLabel: 'process_high' {
                cpus          = 16
                memory        = '64 GB'
                time          = '12 h'
                accelerator   { type = 'nvidia-tesla-a100'; request = 1 }
            }
        }

        google {
            project  = 'your-gcp-project'          // update to your GCP project
            location = 'us-central1'               // update to your region
            lifeSciences.preemptible = true        // cost saving
        }

        workDir = 'gs://your-bucket/nextflow-work' // update to your GCS bucket
    }
}

// ---------------------------------------------------------------------------
// Reporting
// ---------------------------------------------------------------------------
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_trace.tsv"
    fields  = 'task_id,name,status,exit,realtime,cpus,memory,disk,rss,vmem'
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_dag.svg"
}
